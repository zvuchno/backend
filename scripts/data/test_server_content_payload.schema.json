{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fixtures.zvuchno.local/schemas/test-server-content-payload.schema.json",
  "title": "Zvuchno test content import payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["genres", "artists"],
  "properties": {
    "genres": {
      "type": "array",
      "description": "Музыкальные жанры. Скрипт создает отсутствующие по slug.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "slug"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 }
        }
      }
    },
    "merch_kinds": {
      "type": "array",
      "description": "Канонические типы мерча для датасета. Скрипт не создает их, а сопоставляет с типами из /store/merch-kinds/. Рекомендуемые slug: cassette, cap, cd, tshirt, vinyl.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "slug"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 }
        }
      },
      "default": []
    },
    "merch_templates": {
      "type": "array",
      "description": "Шаблоны мерча, применяются к каждому артисту. В строках name/description/property_name доступны {artist} и {artist_slug}.",
      "items": { "$ref": "#/$defs/merch" },
      "default": []
    },
    "artists": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "slug", "albums"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 },
          "city": { "type": "string", "default": "" },
          "genre_slug": { "type": "string" },
          "albums": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "release_date", "genre_slug", "tracks"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "release_date": {
                  "type": "string",
                  "format": "date"
                },
                "genre_slug": { "type": "string", "minLength": 1 },
                "tracks": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "price": {
                  "type": "string",
                  "pattern": "^[0-9]+(\\.[0-9]{2})?$",
                  "default": "199.00"
                },
                "track_price": {
                  "type": "string",
                  "pattern": "^[0-9]+(\\.[0-9]{2})?$",
                  "default": "49.00"
                },
                "allow_overpay": { "type": "boolean", "default": false },
                "visibility": {
                  "type": "string",
                  "enum": ["public", "link_only", "hidden"],
                  "default": "public"
                },
                "is_published": { "type": "boolean", "default": true }
              }
            }
          },
          "merch": {
            "type": "array",
            "description": "Дополнительный мерч только этого артиста.",
            "items": { "$ref": "#/$defs/merch" },
            "default": []
          }
        }
      }
    }
  },
  "$defs": {
    "merch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind_slug", "price", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind_slug": {
          "type": "string",
          "enum": ["cassette", "cap", "cd", "tshirt", "vinyl"],
          "description": "Канонический тип. Скрипт сопоставит его с существующим типом мерча из API по slug/name и известным алиасам."
        },
        "price": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]{2})?$"
        },
        "description": { "type": "string" },
        "album_index": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based индекс альбома артиста, если товар связан с альбомом."
        },
        "allow_overpay": { "type": "boolean", "default": false },
        "visibility": {
          "type": "string",
          "enum": ["public", "link_only", "hidden"],
          "default": "public"
        },
        "is_published": { "type": "boolean", "default": true },
        "property_name": {
          "type": "string",
          "description": "Название свойства вариантов: Размер, Формат, Цвет."
        },
        "stock": {
          "type": "integer",
          "minimum": 0,
          "description": "Используется для простого товара без variants."
        },
        "variants": {
          "type": "array",
          "description": "Если указано, stock задается внутри каждого варианта.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "stock"],
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "stock": { "type": "integer", "minimum": 0 }
            }
          }
        }
      },
      "oneOf": [
        { "required": ["stock"], "not": { "required": ["variants"] } },
        { "required": ["variants"], "not": { "required": ["stock"] } }
      ]
    }
  }
}
