DEBUG=False
USE_SQLITE=False
POSTGRES_DB=zvuchno_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
UID=1002
GID=1002

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

REDIS_URL=redis://redis:6379/2

ALLOWED_HOSTS=127.0.0.1,dev.zvuchno.space,158.160.217.116
CSRF_TRUSTED_ORIGINS=https://dev.zvuchno.space
SECRET_KEY=topsecretkey

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# на PROD заменить. Адреса для примера.
FRONTEND_BASE_URL=https://dev.zvuchno.space
FRONTEND_VERIFY_EMAIL_PATH=/verify/verify-success
FRONTEND_RESET_PASSWORD_PATH=/reset-password-confirm
FRONTEND_SOCIAL_AUTH_PATH=/

GLITCHTIP_DSN=https://somekey@app.glitchtip.com/digits
# 5% запросов для мониторинга.
GLITCHTIP_TRACES_RATE=0.05
# чтобы отличать окружения.
DJANGO_ENV=local

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# email backend
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@dev.zvuchno.space
EMAIL_TIMEOUT=10

# CDEK
CDEK_API_URL=https://api.edu.cdek.ru/v2
CDEK_CLIENT_ID=your_client_id
CDEK_CLIENT_SECRET=your_client_secret
DEFAULT_CITY=Москва # Город по умолчанию
GEO_PROVIDER=ip_api # Провайдер для определения локации пользователя
TARIFF_PICKPOINT=136  # Склад-Склад
TARIFF_COURIER=137 # Склад-Дверь
DEFAULT_ITEM_WEIGHT=300 # Дефолтый вес

# S3
USE_S3_MEDIA=False
# Путь для дев, прод итп.
MEDIA_LOCATION=dev/media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PUBLIC_STORAGE_BUCKET_NAME=
AWS_PRIVATE_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=https://storage.yandexcloud.net
AWS_S3_REGION_NAME=ru-central1
AWS_S3_ADDRESSING_STYLE=path
AWS_QUERYSTRING_AUTH=True
AWS_QUERYSTRING_EXPIRE=120
AWS_S3_FILE_OVERWRITE=False

# bot_telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=zvuchno_dev_bot
TELEGRAM_ADMIN_CHAT_ID=your_chat_id
# Оставьте пустым, если прокси не требуется.
TELEGRAM_PROXY_URL=  # протокол://логин:пароль@ip-адрес:порт
